{
	"name": "co-diagramador",
	"displayName": "Diagramador",
	"description": "Diagramador de templates LaTeX para CO",
	"icon": "resources/co-view.svg",
	"publisher": "odebrino",
	"version": "0.0.1",
	"license": "MIT",
	"dependencies": {
		"co-doc-core": "file:../../packages/co-doc-core",
		"co-preview-core": "file:../../packages/co-preview-core",
		"co-storage-core": "file:../../packages/co-storage-core",
		"co-template-core": "file:../../packages/co-template-core",
		"yauzl": "^3.0.0",
		"yazl": "^2.5.1"
	},
	"engines": {
		"vscode": "^1.90.0"
	},
	"categories": [
		"Other"
	],
	"main": "./out/extension.js",
	"activationEvents": [
		"onView:co.diagramador.blocksView",
		"onCommand:co.diagramador.open",
		"onCommand:co.diagramador.manageTemplates"
	],
	"capabilities": {
		"virtualWorkspaces": true,
		"untrustedWorkspaces": {
			"supported": true
		}
	},
	"devDependencies": {
		"@types/node": "^22.18.10",
		"@types/yauzl": "^2.10.0",
		"@types/yazl": "^2.4.2"
	},
	"contributes": {
		"commands": [
			{ "command": "co.diagramador.open", "title": "CO: Abrir Diagramador" },
			{ "command": "co.diagramador.manageTemplates", "title": "CO: Gerenciar Templates" }
		],
		"menus": {
			"commandPalette": [
				{ "command": "co.diagramador.open" },
				{ "command": "co.diagramador.manageTemplates" }
			]
		},
		"viewsContainers": {
			"activitybar": [
				{ "id": "diagramador", "title": "Diagramador", "icon": "resources/co-view.svg" }
			]
		},
		"views": {
			"diagramador": [
				{
					"id": "co.diagramador.blocksView",
					"name": "Tarefas",
					"type": "webview"
				}
			]
		},
		"configuration": {
			"title": "CO",
			"properties": {
				"co.diagramador.fastBuild": {
					"type": "boolean",
					"default": true,
					"description": "Usa compilacao rapida no Diagramador (menos reruns do Tectonic)."
				},
				"co.runtime.baseDir": {
					"type": "string",
					"default": "",
					"description": "Diretorio base visivel para o runtime de compilacao/preview das extensoes CO."
				},
				"co.tectonic.bundlePath": {
					"type": "string",
					"default": "",
					"description": "Caminho para o bundle offline do Tectonic."
				}
			}
		}
	}
}
