{
	"name": "co-shell",
	"displayName": "CO Shell",
	"description": "Student/Admin shell UI for CO Dev",
	"publisher": "odebrino",
	"version": "0.0.1",
	"license": "MIT",
	"dependencies": {
		"co-template-core": "file:../../packages/co-template-core"
	},
	"engines": {
		"vscode": "^1.90.0"
	},
	"categories": [
		"Other"
	],
	"main": "./out/extension.js",
	"activationEvents": [
		"onStartupFinished",
		"onCommand:coShell.openStudentHome",
		"onCommand:coShell.openAdminHome",
		"onCommand:coShell.enterAdminMode",
		"onCommand:co.diagramador.open",
		"onView:co.diagramador.blocksView"
	],
	"capabilities": {
		"virtualWorkspaces": true,
		"untrustedWorkspaces": {
			"supported": true
		}
	},
	"devDependencies": {
		"@types/node": "^22.18.10"
	},
	"contributes": {
		"commands": [
			{ "command": "coShell.openStudentHome", "title": "CO: Open Student Home" },
			{ "command": "coShell.openAdminHome", "title": "CO: Open Admin Home" },
			{ "command": "coShell.enterAdminMode", "title": "CO: Enter Admin Mode" },
			{ "command": "co.diagramador.open", "title": "CO: Abrir Diagramador" }
		],
		"menus": {
			"commandPalette": [
				{ "command": "co.diagramador.open" },
				{ "command": "coShell.openAdminHome", "when": "co.role == 'admin'" },
				{ "command": "coShell.enterAdminMode", "when": "co.role != 'admin'" }
			]
		},
		"viewsContainers": {
			"activitybar": [
				{ "id": "coShell", "title": "CO", "icon": "resources/co-view.svg" },
				{ "id": "diagramador", "title": "Diagramador", "icon": "resources/co-view.svg" }
			]
		},
		"views": {
			"diagramador": [
				{
					"id": "co.diagramador.blocksView",
					"name": "Template e Dados",
					"type": "webview"
				}
			],
			"coShell": [
				{
					"id": "coShell.adminView",
					"name": "Admin Home",
					"type": "webview",
					"when": "co.role == 'admin'"
				}
			]
		},
		"configuration": {
			"title": "CO Shell",
			"properties": {
				"coShell.closeWorkspace": {
					"type": "boolean",
					"default": true,
					"description": "Fecha o workspace ao entrar no Student Mode (desativado automaticamente em desenvolvimento)."
				},
				"coShell.userEmail": {
					"type": "string",
					"default": "",
					"description": "Email usado para decidir admin via admins.json"
				},
				"coShell.adminsFile": {
					"type": "string",
					"default": "",
					"description": "Caminho opcional para admins.json"
				}
			}
		}
	}
}
